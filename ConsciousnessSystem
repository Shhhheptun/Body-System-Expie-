-- ReplicatedStorage/BodySystem/Systems/ConsciousnessSystem

local Config = require(script.Parent.Parent:WaitForChild("Expie_Config"))

local ConsciousnessSystem = {}

function ConsciousnessSystem.Update(body, dt)

	-- естественное восстановление
	body.Consciousness += 3 * dt

	-- лимиты
	local cap = 100

	cap = math.min(cap, body.Oxygen)
	cap = math.min(cap, body.Parts.Head.Muscle)
	cap = math.min(cap, body.Energy)

	body.Consciousness = math.clamp(body.Consciousness, 0, cap)

	-- состояния
	if body.Consciousness < 20 then
		body.IsUnconscious = true
	else
		body.IsUnconscious = false
	end

end

return ConsciousnessSystem

