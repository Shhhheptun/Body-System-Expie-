local OxygenSystem = {}

local function clamp(v,min,max)
	return math.max(min,math.min(max,v))
end

-- мягкая кривая (без резкого обрыва)
local function getTransportFactor(bloodPercent)
	-- плавная квадратичная кривая
	return bloodPercent * bloodPercent
end

function OxygenSystem.Update(body, dt)

	-- ===== КРОВЬ =====
	local bloodPercent = body.Blood / body.MaxBlood
	local transportFactor = getTransportFactor(bloodPercent)

	-- ===== ЛЁГКИЕ =====
	local lungFactor = 1

	if body.MaxHemothorax > 0 then
		lungFactor = 1 - (body.Hemothorax / body.MaxHemothorax)
	end

	lungFactor = clamp(lungFactor, 0, 1)

	if body.OxygenBlocked then
		lungFactor = 0
	end

	-- ===== ИНТЕЙК =====
	local intakeRate = 40
	local intake = intakeRate * transportFactor * lungFactor

	-- ===== ПОТРЕБЛЕНИЕ =====
	local baseConsumption = 10

	-- лёгкое усиление при низкой крови (НЕ жёсткое)
	local consumption = baseConsumption + (1 - bloodPercent) * 10

	-- ===== ОБНОВЛЕНИЕ =====
	body.Oxygen += (intake - consumption) * dt

	body.Oxygen = clamp(body.Oxygen, body.MinOxygen, body.MaxOxygen)

end

return OxygenSystem
