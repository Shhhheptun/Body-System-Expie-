-- HitboxService
-- ServerScriptService/BodySystem/HitboxService

local HitboxService = {}

local ServerStorage = game:GetService("ServerStorage")

local LimbMap = {

	Head = "Head",
	Chest = "Torso",
	Stomach = "Torso",

	LeftShoulder = "Left Arm",
	LeftForearm = "Left Arm",

	RightShoulder = "Right Arm",
	RightForearm = "Right Arm",

	LeftThigh = "Left Leg",
	LeftShin = "Left Leg",

	RightThigh = "Right Leg",
	RightShin = "Right Leg"

}

function HitboxService.Attach(character)

	local template = ServerStorage.HitboxRig
	local rig = template:Clone()

	rig.Name = "Hitboxes"
	rig.Parent = character

	for _,hitbox in pairs(rig:GetChildren()) do

		local bodyPartName = LimbMap[hitbox.Name]

		if not bodyPartName then
			warn("No LimbMap entry for:", hitbox.Name)
			continue
		end

		local bodyPart = character:FindFirstChild(bodyPartName)

		if not bodyPart then
			warn("Body part not found:", bodyPartName)
			continue
		end

		if bodyPart then

			hitbox.CFrame = bodyPart.CFrame

			local weld = Instance.new("WeldConstraint")
			weld.Part0 = hitbox
			weld.Part1 = bodyPart
			weld.Parent = hitbox
			
			print("Hitboxes attached to:", character.Name)

		end

	end

end


return HitboxService
